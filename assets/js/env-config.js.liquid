/**
 * Environment Configuration Handler
 * Securely loads API credentials from environment variables or secure sources
 */
class EnvironmentConfig {
    constructor() {
        this.config = {};
        this.initialized = false;
    }

    /**
     * Initialize configuration - HARDCODED for GitHub Pages deployment
     */
    async initialize() {
        console.log('[ENV-CONFIG] ========================================');
        console.log('[ENV-CONFIG] Starting initialization...');
        console.log('[ENV-CONFIG] Hostname:', window.location.hostname);
        console.log('[ENV-CONFIG] ========================================');

        // Use hardcoded values for GitHub Pages (like working commit b5cf944)
        await this.loadFromSiteConfig();
        this.initialized = true;

        console.log('[ENV-CONFIG] ========================================');
        console.log('[ENV-CONFIG] Initialization complete!');
        console.log('[ENV-CONFIG] Auth0 Domain:', this.config.auth0.domain);
        console.log('[ENV-CONFIG] Auth0 Client ID:', this.config.auth0.client_id);
        console.log('[ENV-CONFIG] Auth0 Audience:', this.config.auth0.audience);
        console.log('[ENV-CONFIG] Auth0 Callback URL:', this.config.auth0.callback_url);
        console.log('[ENV-CONFIG] Spotify Client ID:', this.config.spotify.client_id);
        console.log('[ENV-CONFIG] Spotify Callback URL:', this.config.spotify.callback_url);
        console.log('[ENV-CONFIG] ========================================');
    }

    /**
     * Load configuration - HARDCODED VALUES (working approach from b5cf944)
     */
    async loadFromSiteConfig() {
        console.log('[ENV-CONFIG] Loading hardcoded configuration...');

        // HARDCODED VALUES - This is how it worked in commit b5cf944
        this.config = {
            auth0: {
                domain: 'dev-l57dcpkhob0u7ykb.us.auth0.com',
                client_id: 'Dq4tBsHjgcIGbXkVU8PPvjAq3WYmnSBC',
                audience: 'https://carsontkempf.github.io/api/carsons-meditations',
                callback_url: 'https://carsontkempf.github.io'
            },
            spotify: {
                client_id: '2321db1768f8416c88d2aefa9dc5284a',
                callback_url: 'https://carsontkempf.github.io/spotify-apple'
            },
            appleMusic: {
                developer_token: 'eyJhbGciOiJFUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IlQ1Wlg2NzZRUlEifQ.eyJpYXQiOjE3NjgzNTUxNzUsImV4cCI6MTc4MzkwNzE3NSwiaXNzIjoiNVM4NTVIQjg5NSJ9.0jmfs0ZKeSx_ARzqIJnOeoaucjH0U16WTuqd9N1K6ZGLAZZimyF4ebXB-aOgvM8BuP08w0SItlhBjW8kQdZGiw',
                team_id: '5S855HB895',
                key_id: 'T5ZX676QRQ',
                private_key: ''
            }
        };

        console.log('[ENV-CONFIG] Hardcoded configuration loaded successfully');
    }


    /**
     * Get Auth0 configuration
     */
    getAuth0Config() {
        if (!this.initialized) {
            throw new Error('Configuration not initialized. Call initialize() first.');
        }
        
        return this.config.auth0;
    }

    /**
     * Get Spotify configuration
     */
    getSpotifyConfig() {
        if (!this.initialized) {
            throw new Error('Configuration not initialized. Call initialize() first.');
        }
        
        const config = this.config.spotify;
        if (!config.client_id) {
            throw new Error('Spotify client ID not found in configuration');
        }
        
        return config;
    }

    /**
     * Get Apple Music configuration
     */
    getAppleMusicConfig() {
        if (!this.initialized) {
            throw new Error('Configuration not initialized. Call initialize() first.');
        }
        
        const config = this.config.appleMusic;
        
        // Return full config including credentials for JWT generation
        return {
            developer_token: config.developer_token || null,
            team_id: config.team_id || '5S855HB895',
            key_id: config.key_id || 'F9Q8YRKX3T',
            private_key: config.private_key || null,
            canGenerateToken: !!(config.team_id && config.key_id && config.private_key)
        };
    }

    /**
     * Check if configuration is ready
     */
    isReady() {
        return this.initialized &&
               this.config.auth0?.client_id &&
               this.config.spotify?.client_id;
    }
}

// Create global instance
window.envConfig = new EnvironmentConfig();

// Initialize immediately when script loads (not waiting for DOMContentLoaded)
// This ensures config is ready before other scripts that depend on it
(async () => {
    try {
        await window.envConfig.initialize();
        console.log('[ENV-CONFIG] Configuration initialized successfully');

        // Dispatch event when config is ready
        window.dispatchEvent(new CustomEvent('configReady', {
            detail: { envConfig: window.envConfig }
        }));
    } catch (error) {
        console.error('[ENV-CONFIG] Failed to initialize environment configuration:', error);

        // Dispatch error event
        window.dispatchEvent(new CustomEvent('configError', {
            detail: { error: error.message }
        }));
    }
})();