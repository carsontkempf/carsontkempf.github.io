// Create the global service object
window.authService = {
    isAuthenticated: false,
    user: null,
    client: null,
    login: () => console.error("Login service not ready."),
    logout: () => console.error("Login service not ready."),
    getApiKey: async () => {
        console.error("API key service not available");
        return null;
    }
};

/* ADD */
// Initialize Auth0 by fetching credentials from Netlify at runtime
async function initializeAuth() {
    console.log('[AUTH] Waiting for environment configuration from Netlify...');

    // Wait for envConfig to be initialized
    if (!window.envConfig || !window.envConfig.initialized) {
        await new Promise(resolve => {
            window.addEventListener('configReady', resolve, { once: true });
        });
    }

    console.log('[AUTH] Environment config ready, loading Auth0 configuration...');

    // Get Auth0 configuration from envConfig service (which fetches from Netlify)
    let config;
    try {
        const envAuth0Config = window.envConfig.getAuth0Config();
        config = {
            domain: envAuth0Config.domain,
            clientId: envAuth0Config.client_id,
            audience: envAuth0Config.audience
        };

        console.log('[AUTH] Auth0 config loaded from Netlify:', {
            domain: config.domain,
            clientId: config.clientId,
            audience: config.audience
        });
    } catch (error) {
        console.error('[AUTH] Failed to get Auth0 config from Netlify:', error);
        throw error;
    }

    // Validate configuration
    if (!config.domain || config.domain === '' || config.domain.includes('${')) {
        throw new Error(`Invalid Auth0 domain: ${config.domain}. Check Netlify environment variables.`);
    }
    if (!config.clientId || config.clientId === '' || config.clientId.includes('${')) {
        throw new Error(`Invalid Auth0 client_id: ${config.clientId}. Check Netlify environment variables.`);
    }
    if (!config.audience || config.audience === '' || config.audience.includes('${')) {
        throw new Error(`Invalid Auth0 audience: ${config.audience}. Check Netlify environment variables.`);
    }

    try {
        // 1. Create the Auth0 client with REFRESH TOKEN support
        // Use /dashboard/ path to match Auth0 allowed callbacks
        const redirectUri = window.location.origin + '/dashboard/';
        console.log('[DEBUG] Starting Auth0 initialization...');
        console.log('[DEBUG] Auth0 Configuration:', {
            domain: config.domain,
            clientId: config.clientId,
            audience: config.audience,
            redirectUri: redirectUri,
            currentUrl: window.location.href
        });

        // DEBUG: Verify Auth0 SDK is loaded
        if (!window.auth0) {
            console.error('[DEBUG] Auth0 SDK not loaded! window.auth0 is undefined');
            throw new Error('Auth0 SDK not loaded');
        }
        console.log('[DEBUG] Auth0 SDK loaded successfully');

        console.log('[DEBUG] Creating Auth0 client...');
        const auth0Client = await window.auth0.createAuth0Client({
            domain: config.domain,
            clientId: config.clientId,
            authorizationParams: {
                redirect_uri: redirectUri,
                audience: config.audience
            },
            useRefreshTokens: true,
            cacheLocation: 'localstorage'
        });
        console.log('[DEBUG] Auth0 client created successfully');
        window.authService.client = auth0Client;

        // 2. Handle the user returning from Auth0
        if (window.location.search.includes('code=') && window.location.search.includes('state=')) {
            await auth0Client.handleRedirectCallback();
            window.history.replaceState({}, document.title, '/dashboard/');
            window.location.href = '/dashboard/';
            return;
        }

        // 3. Check the session and update the state
        const isAuthenticated = await auth0Client.isAuthenticated();
        window.authService.isAuthenticated = isAuthenticated;
        if (isAuthenticated) {
            window.authService.user = await auth0Client.getUser();
        }

        // 4. Define the global login/logout methods
        window.authService.login = () => auth0Client.loginWithRedirect();
        window.authService.logout = () => auth0Client.logout({
            logoutParams: { returnTo: window.location.origin }
        });

        // 4b. Define getApiKey method
        window.authService.getApiKey = async () => {
            if (!isAuthenticated) {
                throw new Error('User not authenticated');
            }

            try {
                const token = await auth0Client.getTokenSilently();
                const response = await fetch('/.netlify/functions/get-api-key', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (!response.ok) {
                    throw new Error(`Failed to get API key: ${response.status}`);
                }

                const data = await response.json();
                return data.apiKey || data.key || JSON.stringify(data);
            } catch (error) {
                console.error('Error getting API key:', error);
                return null;
            }
        };

        // 5. Get references to the UI buttons
        const loginBtn = document.getElementById('btn-login');
        const dashboardBtn = document.getElementById('btn-dashboard');
        const logoutBtn = document.getElementById('btn-logout');

        // 6. Update button visibility based on auth state and page location
        if (isAuthenticated) {
            if (loginBtn) loginBtn.style.display = 'none';
            
            // Show logout button ONLY on exact /dashboard/ page
            const isOnExactDashboard = window.location.pathname === '/dashboard/' || window.location.pathname === '/dashboard';
            
            if (isOnExactDashboard) {
                if (dashboardBtn) dashboardBtn.style.display = 'none';
                if (logoutBtn) logoutBtn.style.display = 'inline-block';
            } else {
                // Show dashboard button on all other pages when authenticated
                if (dashboardBtn) dashboardBtn.style.display = 'inline-block';
                if (logoutBtn) logoutBtn.style.display = 'none';
            }
        } else {
            if (loginBtn) loginBtn.style.display = 'inline-block';
            if (dashboardBtn) dashboardBtn.style.display = 'none';
            if (logoutBtn) logoutBtn.style.display = 'none';
        }

        // 7. Wire up the buttons to the auth service methods
        if (loginBtn) {
            loginBtn.addEventListener('click', (e) => {
                e.preventDefault();
                window.authService.login();
            });
        }
        if (logoutBtn) {
            logoutBtn.addEventListener('click', (e) => {
                e.preventDefault();
                window.authService.logout();
            });
        }

        // 8. Fire the "ready" event for page-specific scripts
        document.dispatchEvent(new CustomEvent('authReady'));

    } catch (error) {
        console.error('[DEBUG] Fatal Error during Auth0 Initialization');
        console.error('[DEBUG] Error type:', error.constructor.name);
        console.error('[DEBUG] Error message:', error.message);
        console.error('[DEBUG] Error stack:', error.stack);
        console.error('[DEBUG] Full error object:', error);

        // Additional network-specific debugging
        if (error.message && error.message.includes('Failed to fetch')) {
            console.error('[DEBUG] Network error detected - could be CORS or DNS issue');
            console.error('[DEBUG] Trying to reach:', `https://${config.domain}`);
        }

        console.error("Fatal Error during Auth0 Initialization:", error);
    }
}

// Initialize auth when DOM is ready
document.addEventListener('DOMContentLoaded', initializeAuth);